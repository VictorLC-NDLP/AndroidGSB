<?xml version="1.0" encoding="utf-8" ?>
<!-- Formulaire de saisie d'un nouvel echantillon -->
<!-- Chaque Entry est lie a une propriete du AjoutEchantillonViewModel via data binding -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AndroidGSB.Views.AjoutEchantillonPage"
             Title="Saisie d'un échantillon"
             BackgroundColor="#1a472a">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,20"
            Spacing="15">

            <Label
                Text="🌿 Saisie d'un échantillon :"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="#f1f3f1"
                FontFamily="OpenSansRegular"/>

            <!-- Champ code produit -->
            <Entry
                Placeholder="Saisir ici un code"
                PlaceholderColor="#d4d8d4"
                Text="{Binding CodeProduit}"
                TextColor="#f1f3f1"
                BackgroundColor="#2d6a4f"
                FontFamily="OpenSansRegular"/>

            <!-- Champ libelle produit -->
            <Entry
                Placeholder="Saisir ici un libellé"
                PlaceholderColor="#d4d8d4"
                Text="{Binding LibelleProduit}"
                TextColor="#f1f3f1"
                BackgroundColor="#2d6a4f"
                FontFamily="OpenSansRegular"/>

            <!-- Champ stock initial (numerique) -->
            <Entry
                Placeholder="Saisir ici un stock"
                PlaceholderColor="#d4d8d4"
                Text="{Binding StockSaisi}"
                Keyboard="Numeric"
                TextColor="#f1f3f1"
                BackgroundColor="#2d6a4f"
                FontFamily="OpenSansRegular"/>

            <!-- Boutons d'action : ajouter ou quitter -->
            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="10"
                Margin="0,10,0,0">

                <Button
                    Grid.Column="0"
                    Text="✓ Ajouter"
                    Command="{Binding AjouterEchantillonCommand}"
                    BackgroundColor="#40916c"
                    TextColor="#f1f3f1"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    Padding="10"
                    FontFamily="OpenSansRegular"/>

                <Button
                    Grid.Column="1"
                    Text="✕ Quitter"
                    Command="{Binding QuitterCommand}"
                    BackgroundColor="#d62828"
                    TextColor="#f1f3f1"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    Padding="10"
                    FontFamily="OpenSansRegular"/>

            </Grid>

            <!-- Indicateur de chargement pendant l'ecriture en base -->
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="#52b788"
                Margin="0,10"/>

            <!-- Message de retour : succes ou erreur -->
            <Label
                Text="{Binding MessageResultat}"
                TextColor="#d4d8d4"
                FontSize="12"
                Margin="0,20,0,0"
                LineBreakMode="WordWrap"
                FontFamily="OpenSansRegular"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

