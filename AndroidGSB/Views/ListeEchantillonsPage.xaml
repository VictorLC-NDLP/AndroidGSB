<?xml version="1.0" encoding="utf-8" ?>
<!-- Liste des echantillons en stock -->
<!-- Utilise une CollectionView avec un template personnalise pour chaque item -->
<!-- Le convertisseur CodeToImageConverter associe automatiquement l'image au code produit -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:AndroidGSB.Converters"
             x:Class="AndroidGSB.Views.ListeEchantillonsPage"
             Title="Liste des échantillons"
             BackgroundColor="#1a472a">

    <VerticalStackLayout
        Padding="10"
        Spacing="10">

        <ActivityIndicator
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Color="#52b788"/>

        <!-- Liste liee a la collection Echantillons du ViewModel -->
        <CollectionView
            ItemsSource="{Binding Echantillons}"
            SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <!-- Carte representant un echantillon -->
                    <Frame
                        Padding="10"
                        Margin="0,5"
                        CornerRadius="12"
                        BackgroundColor="#2d6a4f"
                        BorderColor="#40916c"
                        HasShadow="True">
                        <Grid
                            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                            ColumnDefinitions="100,*,Auto">

                            <!-- Image du produit -->
                            <Image
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.RowSpan="7"
                                Source="{Binding CodeProduit, Converter={StaticResource CodeToImageConverter}}"
                                Aspect="AspectFill"
                                WidthRequest="100"
                                HeightRequest="100"
                                VerticalOptions="Start"
                                Margin="0,0,10,0"/>

                            <!-- Code produit + stock mini -->
                            <Label
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding CodeProduit, StringFormat='Code: {0}'}"
                                FontAttributes="Bold"
                                TextColor="#52b788"
                                FontSize="14"
                                FontFamily="OpenSansRegular"/>

                            <Label
                                Grid.Row="0"
                                Grid.Column="2"
                                Text="{Binding StockMini, StringFormat='Mini: {0}'}"
                                TextColor="#d4d8d4"
                                FontSize="12"
                                FontFamily="OpenSansRegular"/>

                            <!-- Libellé -->
                            <Label
                                Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding LibelleProduit}"
                                TextColor="#f1f3f1"
                                FontSize="14"
                                FontAttributes="Bold"
                                Margin="0,4,0,0"
                                FontFamily="OpenSansRegular"/>

                            <!-- Description -->
                            <Label
                                Grid.Row="2"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding Description}"
                                TextColor="#d4d8d4"
                                FontSize="11"
                                FontAttributes="Italic"
                                Margin="0,2,0,0"
                                IsVisible="{Binding Description, Converter={StaticResource StringNotEmptyConverter}}"
                                FontFamily="OpenSansRegular"/>

                            <!-- Dosage -->
                            <Label
                                Grid.Row="3"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding Dosage, StringFormat='Dosage : {0}'}"
                                TextColor="#b7e4c7"
                                FontSize="11"
                                Margin="0,4,0,0"
                                IsVisible="{Binding Dosage, Converter={StaticResource StringNotEmptyConverter}}"
                                FontFamily="OpenSansRegular"/>

                            <!-- Conseils -->
                            <Label
                                Grid.Row="4"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding Conseils, StringFormat='Conseils : {0}'}"
                                TextColor="#95d5b2"
                                FontSize="11"
                                Margin="0,2,0,0"
                                IsVisible="{Binding Conseils, Converter={StaticResource StringNotEmptyConverter}}"
                                FontFamily="OpenSansRegular"/>

                            <!-- Complément -->
                            <Label
                                Grid.Row="5"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding Complement, StringFormat='Complément : {0}'}"
                                TextColor="#95d5b2"
                                FontSize="11"
                                Margin="0,2,0,0"
                                IsVisible="{Binding Complement, Converter={StaticResource StringNotEmptyConverter}}"
                                FontFamily="OpenSansRegular"/>

                            <!-- Stock actuel -->
                            <Label
                                Grid.Row="6"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding Stock, StringFormat='Stock : {0}'}"
                                TextColor="#40916c"
                                FontSize="12"
                                FontAttributes="Bold"
                                Margin="0,6,0,0"
                                FontFamily="OpenSansRegular"/>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Text="🚪 Quitter"
            Command="{Binding QuitterCommand}"
            BackgroundColor="#d62828"
            TextColor="#f1f3f1"
            FontAttributes="Bold"
            CornerRadius="10"
            Padding="15,10"
            HorizontalOptions="Fill"
            FontFamily="OpenSansRegular"/>

    </VerticalStackLayout>

</ContentPage>

