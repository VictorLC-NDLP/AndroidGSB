<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:AndroidGSB.Converters"
             x:Class="AndroidGSB.Views.ListeEchantillonsPage"
             Title="Liste des échantillons"
             BackgroundColor="#1a472a">

    <VerticalStackLayout
        Padding="10"
        Spacing="10">

        <ActivityIndicator
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Color="#52b788"/>

        <CollectionView
            ItemsSource="{Binding Echantillons}"
            SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame
                        Padding="10"
                        Margin="0,5"
                        CornerRadius="12"
                        BackgroundColor="#2d6a4f"
                        BorderColor="#40916c"
                        HasShadow="True">
                        <Grid
                            RowDefinitions="Auto,Auto,Auto,Auto"
                            ColumnDefinitions="100,*,Auto">

                            <!-- Image du produit -->
                            <Image
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.RowSpan="4"
                                Source="{Binding CodeProduit, Converter={StaticResource CodeToImageConverter}}"
                                Aspect="AspectFill"
                                WidthRequest="100"
                                HeightRequest="100"
                                Margin="0,0,10,0"/>

                            <Label
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding CodeProduit, StringFormat='Code: {0}'}"
                                FontAttributes="Bold"
                                TextColor="#52b788"
                                FontSize="14"
                                FontFamily="OpenSansRegular"/>

                            <Label
                                Grid.Row="0"
                                Grid.Column="2"
                                Text="{Binding StockMini, StringFormat='Mini: {0}'}"
                                TextColor="#d4d8d4"
                                FontSize="12"
                                FontFamily="OpenSansRegular"/>

                            <Label
                                Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding LibelleProduit}"
                                TextColor="#f1f3f1"
                                FontSize="14"
                                Margin="0,5,0,0"
                                FontFamily="OpenSansRegular"/>

                            <Label
                                Grid.Row="2"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding Description}"
                                TextColor="#d4d8d4"
                                FontSize="11"
                                Margin="0,3,0,0"
                                FontFamily="OpenSansRegular"/>

                            <Label
                                Grid.Row="3"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                TextColor="#40916c"
                                FontSize="12"
                                FontAttributes="Bold"
                                Margin="0,5,0,0"
                                FontFamily="OpenSansRegular"/>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Text="🚪 Quitter"
            Command="{Binding QuitterCommand}"
            BackgroundColor="#d62828"
            TextColor="#f1f3f1"
            FontAttributes="Bold"
            CornerRadius="10"
            Padding="15,10"
            HorizontalOptions="Fill"
            FontFamily="OpenSansRegular"/>

    </VerticalStackLayout>

</ContentPage>

