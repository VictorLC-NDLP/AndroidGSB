<?xml version="1.0" encoding="UTF-8" ?>
<!-- Configuration du Shell : navigation principale de l'application -->
<!-- FlyoutBehavior="Disabled" : pas de menu lateral, navigation par boutons uniquement -->
<!-- La page d'accueil MainPage est chargee par defaut via ShellContent -->
<Shell
    x:Class="AndroidGSB.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AndroidGSB"
    xmlns:views="clr-namespace:AndroidGSB.Views"
    Title="GSB Stock Échantillons"
    FlyoutBehavior="Disabled"
    BackgroundColor="#1a1a2e">

    <ShellContent
        Title="Accueil"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
