<?xml version = "1.0" encoding = "UTF-8" ?>
<!-- Ressources globales de l'application -->
<!-- Fusionne les dictionnaires de styles (Colors.xaml, Styles.xaml) -->
<!-- Declare le convertisseur CodeToImageConverter utilise dans les vues -->
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:AndroidGSB.Converters"
             x:Class="AndroidGSB.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:CodeToImageConverter x:Key="CodeToImageConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
